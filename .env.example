# Superuser DSN — used only by the migration runner (DDL, roles, extensions).
ADMIN_DATABASE_URL=postgresql://postgres:postgres@localhost:5433/infra_twin

# Application DSN — non-superuser role; Row-Level Security is enforced on this role.
DATABASE_URL=postgresql://app:app@localhost:5433/infra_twin

# Shared secret authorizing POST /tenants (bootstrap admin). No default; unset => 503.
INFRA_TWIN_BOOTSTRAP_ADMIN_TOKEN=

# Anthropic API key for the natural-language query surface (POST /ask). Server-side only —
# never expose this to the web frontend. Unset => /ask returns 503 (the rest of the API works).
ANTHROPIC_API_KEY=

# Optional: override the model used to compile NL questions to templated queries.
# Defaults to claude-sonnet-4-6 (each /ask call is a tiny request). Use claude-opus-4-8 for
# the most capable model.
# INFRA_TWIN_NL_MODEL=claude-sonnet-4-6

# infra-twin AWS account used as the trust principal for customer onboarding roles.
# Set to your infra-twin service's AWS account ID (12-digit). No default; unset => 503 on the onboarding endpoint.
# INFRA_TWIN_AWS_TRUSTER_ACCOUNT_ID=

# Optional: a specific infra-twin IAM role ARN to use as the trust principal instead of :root.
# When set, takes precedence over INFRA_TWIN_AWS_TRUSTER_ACCOUNT_ID.
# INFRA_TWIN_AWS_TRUSTER_ROLE_ARN=
